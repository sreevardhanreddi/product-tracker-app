# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=changeme-use-openssl-rand-hex-32
LOG_LEVEL=INFO

# ── Database ───────────────────────────────────────────────────────────────────
# For local dev (no Docker): postgresql://tracker:tracker@localhost:5432/tracker
# For Docker Compose dev:    postgresql://tracker:tracker@postgres:5432/tracker
DATABASE_URL=postgresql://tracker:tracker@postgres:5432/tracker

# Used by docker-compose.prod.yml directly
POSTGRES_USER=tracker
POSTGRES_PASSWORD=tracker
POSTGRES_DB=tracker

# ── Redis / Celery ─────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Price Check Schedule ───────────────────────────────────────────────────────
PRICE_CHECK_INTERVAL_MINUTES=60

# ── Alerts (all optional — falls back to logging if not set) ───────────────────
# Gmail — use an App Password, not your regular account password
# https://support.google.com/accounts/answer/185833
GMAIL_USER=
GMAIL_PASSWORD=
ALERT_TO_EMAIL=   # defaults to GMAIL_USER if blank

# Telegram — create a bot via @BotFather, get your chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Monitoring ─────────────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Playwright ─────────────────────────────────────────────────────────────────
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=30000
